# ============================================================
# Butler — 环境变量模板
# 复制本文件为 .env.local 后填入真实值，.env.local 已被 .gitignore 忽略
# ============================================================

# DeepSeek API（必填，用于 /api/chat 路由）
# 申请：https://platform.deepseek.com → 充值 → API Keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：模型与 baseURL（默认走官方 DeepSeek，无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ============================================================
# Database login (temporary SQLite account store)
# Leave empty to use apps/web/data/butler.sqlite in local development.
# For Docker Compose this is set to /app/data/butler.sqlite.
# ============================================================
BUTLER_SQLITE_PATH=

# ============================================================
# OCR 多模态（可选，用于扫描件 PDF + 图片课件识别）
# 申请：https://console.mistral.ai/ → API Keys
# 价格：$0.001/页（1000 页 $1，业内最便宜专业 OCR）
# 未填则上传扫描件/图片会报错；只用文字型 PDF 不需要
# ============================================================
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# OCR provider 选择：mistral（默认） / deepseek-vl（占位） / tesseract（占位）
# 后两个尚未实现接入，保留 mistral 即可
OCR_PROVIDER=mistral
